# ZStack connection
ZSTACK_ENDPOINT=http://zstack-mgmt:8080
ZSTACK_ACCESS_KEY_ID=your_access_key_id
ZSTACK_ACCESS_KEY_SECRET=your_access_key_secret
ZSTACK_POLL_INTERVAL_SECONDS=300

# Database (overridden by docker-compose for container deployment)
DATABASE_URL=postgresql+asyncpg://elicloud:elicloud@postgres:5432/elicloudmonitor

# App
APP_PORT=8000
APP_ENV=production
SECRET_KEY=change-me-to-a-random-secret

# Frontend (Vite build-time variable)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:80
